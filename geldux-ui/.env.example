# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# ── Alchemy ───────────────────────────────────────────────────────────────
# Get a free key at https://alchemy.com — create a Base Sepolia app.
VITE_ALCHEMY_API_KEY=your_alchemy_api_key_here

# ── Supabase ──────────────────────────────────────────────────────────────
# The anon key is intentionally public (row-level security enforced server-side),
# but keep it in env vars to avoid accidental swaps between projects.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Feature flags (true / false) ─────────────────────────────────────────
VITE_ENABLE_PERPS=true
VITE_ENABLE_SPOT=true
