# Copy to .env.local and fill in real values — never commit .env.local

# Primary RPC — used for all reads: prices, positions, balances, history
VITE_PRIMARY_RPC=https://base-sepolia.g.alchemy.com/v2/your_primary_key_here

# Secondary RPC — automatic fallback if primary fails or is unavailable
VITE_SECONDARY_RPC=https://base-sepolia.g.alchemy.com/v2/your_secondary_key_here

# Supabase — indexed history layer (optional but strongly recommended)
# Without Supabase, history is fetched live from the chain on every load.
# With Supabase, history loads instantly from cache; only new blocks are scanned.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
