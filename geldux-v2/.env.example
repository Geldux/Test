# Copy to .env.local and fill in real values — never commit .env.local

# Alchemy Base Sepolia — normal state/balance reads
VITE_ALCHEMY_READ_RPC=https://base-sepolia.g.alchemy.com/v2/your_read_key_here

# Alchemy Base Sepolia — dedicated history / event queries (eth_getLogs)
# When set, enables ~11.6-day lookback; without it falls back to ~2.3-day public-RPC limit.
VITE_ALCHEMY_HISTORY_RPC=https://base-sepolia.g.alchemy.com/v2/your_history_key_here

# Supabase (optional — for leaderboard / notifications)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
